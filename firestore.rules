rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function groupPath(groupId) {
      return /databases/$(database)/documents/groups/$(groupId);
    }

    function groupData(groupId) {
      return get(groupPath(groupId)).data;
    }

    function isGroupMember(groupId) {
      return isSignedIn() && request.auth.uid in groupData(groupId).memberUids;
    }

    function isGroupProtectedUnchanged() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.name == resource.data.name
        && request.resource.data.joinCode == resource.data.joinCode
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.maxMembers == resource.data.maxMembers
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.gameStartedAt == resource.data.gameStartedAt
        && request.resource.data.gameEndedAt == resource.data.gameEndedAt
        && request.resource.data.gameExpiresAt == resource.data.gameExpiresAt;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
                    && request.resource.data.uid == uid;
      allow update: if isOwner(uid)
                    && request.resource.data.uid == uid
                    && (
                      resource.data.uid == null
                      || request.resource.data.uid == resource.data.uid
                    );
      allow delete: if false;
    }

    match /groups/{groupId} {
      // 참여 전에는 waiting 그룹만 조회 가능 (참여코드 조회용)
      allow read: if isSignedIn()
                  && (
                    request.auth.uid in resource.data.memberUids
                    || resource.data.status == 'waiting'
                  );

      allow create: if isSignedIn()
                    && request.resource.data.id == groupId
                    && request.resource.data.hostUid == request.auth.uid
                    && request.resource.data.status == 'waiting';

      allow update: if isSignedIn()
                    && isGroupProtectedUnchanged()
                    && (
                      // Case 1: joinGroup - 자기 자신 1명만 추가
                      (
                        !(request.auth.uid in resource.data.memberUids)
                        && resource.data.status == 'waiting'
                        && resource.data.memberUids.size() < resource.data.maxMembers
                        && request.resource.data.memberUids.hasAll(resource.data.memberUids)
                        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
                        && request.auth.uid in request.resource.data.memberUids
                        && request.resource.data.memberNicknames == resource.data.memberNicknames
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberUids'])
                      )
                      ||
                      // Case 2: member nickname update - 본인 닉네임만 변경
                      (
                        request.auth.uid in resource.data.memberUids
                        && request.resource.data.memberUids == resource.data.memberUids
                        && request.resource.data.memberNicknames.diff(resource.data.memberNicknames).affectedKeys().hasOnly([request.auth.uid])
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberNicknames'])
                      )
                    );

      allow delete: if false;

      match /bombs/{bombId} {
        allow read: if isGroupMember(groupId);

        // passBomb: 현재 보유자만 holderUid/receivedAt/expiresAt 변경 가능
        allow update: if isGroupMember(groupId)
                      && resource.data.status == 'active'
                      && request.auth.uid == resource.data.holderUid
                      && request.resource.data.holderUid in groupData(groupId).memberUids
                      && request.resource.data.holderUid != request.auth.uid
                      && request.resource.data.status == resource.data.status
                      && request.resource.data.id == resource.data.id
                      && request.resource.data.groupId == resource.data.groupId
                      && request.resource.data.round == resource.data.round
                      && request.resource.data.explodedUid == resource.data.explodedUid
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                        'holderUid',
                        'receivedAt',
                        'expiresAt'
                      ]);

        allow create, delete: if false;
      }

      // 아이템 사용 로그: 멤버 읽기 전용 (Cloud Functions만 기록)
      match /itemUsages/{usageId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if false;
      }

      // pass 로그: 멤버 읽기, 멤버 본인(fromUid)만 생성
      match /passes/{passId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
                      && request.resource.data.fromUid == request.auth.uid
                      && request.resource.data.toUid in groupData(groupId).memberUids
                      && request.resource.data.keys().hasOnly([
                        'fromUid',
                        'toUid',
                        'timestamp'
                      ]);
        allow update, delete: if false;
      }
    }

    match /shopItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /missions/{missionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
